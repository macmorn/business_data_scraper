# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional API keys (leave blank if not using)
BRAVE_API_KEY=
PAPPERS_API_KEY=
OPENCORPORATES_API_KEY=

# Rate limits
NORTHDATA_DELAY_SECONDS=2.5

# Paths
INPUT_PDF=input/companies.pdf
OUTPUT_CSV=output/companies_enriched.csv
DB_PATH=data/pipeline.db

# PDF layout profile (see pdf_layouts.py for options)
# Options: airbus_suppliers, simple_name_list
PDF_LAYOUT=airbus_suppliers

# Claude model for disambiguation + career summaries
CLAUDE_MODEL=claude-sonnet-4-20250514

# Pipeline settings
MAX_RETRIES=3
LOG_FILE=output/pipeline.log
